{
  "_meta": {
    "note": "Canonical schema for .planning/config.json. Source of truth for keys, types, enums, and defaults. Validated by bin/config.mjs; the cad-config workflow catalog is derived from this. Enum provenance: [repo] = pinned in DESIGN/references; [proposed] = plausible label the executing model honors, no runtime validator beyond membership.",
    "types": "bool | int | string | string_or_null | enum | array_string | array_enum. int accepts an optional 'min'. enum/array_enum carry 'values'."
  },
  "keys": {
    "mode":                                 { "type": "enum", "values": ["interactive"], "default": "interactive", "src": "repo", "purpose": "How the loop runs (autonomous/audit-fix cut in DESIGN:111)" },
    "granularity":                          { "type": "enum", "values": ["fine", "standard", "coarse"], "default": "standard", "src": "proposed", "purpose": "How finely phases split into tasks" },
    "context_window":                       { "type": "int", "min": 1, "default": 1000000, "purpose": "Model context budget (tokens) used for chunking" },

    "model.profile":                        { "type": "enum", "values": ["fast", "balanced", "quality"], "default": "balanced", "src": "proposed", "purpose": "Quality/cost tier for agents" },
    "model.auto.ceiling":                   { "type": "enum", "values": ["fast", "balanced", "quality"], "default": "quality", "src": "proposed", "purpose": "Highest tier auto-escalation may reach" },
    "model.auto.escalate_on_failure":       { "type": "bool", "default": true, "purpose": "Bump the tier after a failed attempt" },
    "model.auto.max_escalations":           { "type": "int", "min": 0, "default": 1, "purpose": "How many times to escalate before giving up" },

    "workflow.research":                    { "type": "bool", "default": false, "purpose": "Run a research pass before planning" },
    "workflow.plan_check":                  { "type": "bool", "default": true, "purpose": "Gate plans through the checker before code" },
    "workflow.verifier":                    { "type": "bool", "default": true, "purpose": "Goal-backward verification after a phase" },
    "workflow.auto_advance":                { "type": "bool", "default": false, "purpose": "Roll into the next phase without asking" },
    "workflow.discuss_mode":                { "type": "enum", "values": ["discuss"], "default": "discuss", "src": "repo", "purpose": "Pre-plan discussion (3 gates collapsed to 1, DESIGN:54); skip_discuss disables it" },
    "workflow.skip_discuss":                { "type": "bool", "default": false, "purpose": "Skip the discussion step entirely" },
    "workflow.human_verify_mode":           { "type": "enum", "values": ["end-of-phase", "per-task", "off"], "default": "end-of-phase", "src": "proposed", "purpose": "When you're asked to UAT" },
    "workflow.subagent_timeout":            { "type": "int", "min": 1, "default": 300000, "purpose": "ms before a subagent is killed" },
    "workflow.inline_plan_threshold":       { "type": "int", "min": 0, "default": 3, "purpose": "Task count at/below which a plan runs inline vs its own doc" },
    "workflow.test_command":                { "type": "string_or_null", "default": null, "purpose": "Command Cadence runs to test (null = none)" },
    "workflow.build_command":               { "type": "string_or_null", "default": null, "purpose": "Command Cadence runs to build (null = none)" },

    "parallelization.enabled":              { "type": "bool", "default": false, "purpose": "Run independent plans concurrently" },
    "parallelization.max_concurrent_agents":{ "type": "int", "min": 1, "default": 3, "purpose": "Cap on simultaneous agents" },
    "parallelization.min_plans_for_parallel":{ "type": "int", "min": 1, "default": 2, "purpose": "Min plans before going parallel" },
    "parallelization.use_worktrees":        { "type": "bool", "default": true, "purpose": "Isolate parallel writes in git worktrees" },

    "git.protected_branches":               { "type": "array_string", "default": ["main", "master"], "purpose": "Branches Cadence won't commit to directly" },
    "git.on_protected":                     { "type": "enum", "values": ["ask", "refuse", "allow"], "default": "ask", "src": "repo", "purpose": "What to do on a protected branch (DESIGN:354)" },
    "git.base_branch":                      { "type": "string_or_null", "default": null, "purpose": "Branch new work branches off (null = current)" },
    "git.auto_push":                        { "type": "bool", "default": false, "purpose": "Push after committing" },
    "git.create_tag":                       { "type": "bool", "default": true, "purpose": "Tag on milestone" },

    "planning.commit_docs":                 { "type": "bool", "default": true, "purpose": "Commit .planning docs alongside code" },

    "search.brave_search":                  { "type": "bool", "default": false, "purpose": "Enable Brave web-search provider" },
    "search.firecrawl":                     { "type": "bool", "default": false, "purpose": "Enable Firecrawl provider" },
    "search.exa_search":                    { "type": "bool", "default": false, "purpose": "Enable Exa provider" },

    "memory.backend":                       { "type": "enum", "values": ["none"], "default": "none", "src": "repo", "purpose": "Where notes/observations route (only 'none' wired today)" },

    "review.mode":                          { "type": "enum", "values": ["single", "panel", "adjudicated"], "default": "adjudicated", "src": "repo", "purpose": "How multiple reviewers combine (review-triggers.md:58)" },
    "review.reviewers":                     { "type": "array_enum", "values": ["claude-subagent", "openai", "gemini"], "default": ["claude-subagent"], "src": "repo", "purpose": "Which reviewer backends fire() resolves (review-triggers.md:30)" },
    "review.key_file":                      { "type": "string_or_null", "default": null, "purpose": "Path override for the provider key env file (never a key)" },

    "review.providers.openai.tiers.flagship":  { "type": "string_or_null", "default": null, "purpose": "OpenAI model id for the flagship tier (set by --review)" },
    "review.providers.openai.tiers.balanced":  { "type": "string_or_null", "default": null, "purpose": "OpenAI model id for the balanced tier" },
    "review.providers.openai.tiers.cheap":     { "type": "string_or_null", "default": null, "purpose": "OpenAI model id for the cheap tier" },
    "review.providers.gemini.tiers.flagship":  { "type": "string_or_null", "default": null, "purpose": "Gemini model id for the flagship tier" },
    "review.providers.gemini.tiers.balanced":  { "type": "string_or_null", "default": null, "purpose": "Gemini model id for the balanced tier" },
    "review.providers.gemini.tiers.cheap":     { "type": "string_or_null", "default": null, "purpose": "Gemini model id for the cheap tier" },

    "review.triggers.plan.gate":            { "type": "enum", "values": ["off", "advisory", "blocking", "adjudicated"], "default": "adjudicated", "src": "repo", "purpose": "How the plan review gates" },
    "review.triggers.plan.tier":            { "type": "enum", "values": ["flagship", "balanced", "cheap"], "default": "flagship", "src": "repo", "purpose": "Model tier for plan review" },
    "review.triggers.plan.effort":          { "type": "enum", "values": ["minimal", "low", "medium", "high"], "default": "high", "src": "repo", "purpose": "Reasoning effort for plan review" },
    "review.triggers.diff.gate":            { "type": "enum", "values": ["off", "advisory", "blocking", "adjudicated"], "default": "advisory", "src": "repo", "purpose": "How the diff review gates" },
    "review.triggers.diff.tier":            { "type": "enum", "values": ["flagship", "balanced", "cheap"], "default": "balanced", "src": "repo", "purpose": "Model tier for diff review" },
    "review.triggers.diff.effort":          { "type": "enum", "values": ["minimal", "low", "medium", "high"], "default": "medium", "src": "repo", "purpose": "Reasoning effort for diff review" },
    "review.triggers.risk_surface.gate":    { "type": "enum", "values": ["off", "advisory", "blocking", "adjudicated"], "default": "blocking", "src": "repo", "purpose": "How the risk-surface review gates" },
    "review.triggers.risk_surface.tier":    { "type": "enum", "values": ["flagship", "balanced", "cheap"], "default": "flagship", "src": "repo", "purpose": "Model tier for risk-surface review" },
    "review.triggers.risk_surface.effort":  { "type": "enum", "values": ["minimal", "low", "medium", "high"], "default": "high", "src": "repo", "purpose": "Reasoning effort for risk-surface review" },
    "review.triggers.pre_ship.gate":        { "type": "enum", "values": ["off", "advisory", "blocking", "adjudicated"], "default": "adjudicated", "src": "repo", "purpose": "How the pre-ship review gates" },
    "review.triggers.pre_ship.tier":        { "type": "enum", "values": ["flagship", "balanced", "cheap"], "default": "flagship", "src": "repo", "purpose": "Model tier for pre-ship review" },
    "review.triggers.pre_ship.effort":      { "type": "enum", "values": ["minimal", "low", "medium", "high"], "default": "high", "src": "repo", "purpose": "Reasoning effort for pre-ship review" },

    "review.consult.enabled":               { "type": "bool", "default": false, "purpose": "Allow a second-model consult at dead-ends" },
    "review.consult.tier":                  { "type": "enum", "values": ["flagship", "balanced", "cheap"], "default": "flagship", "src": "repo", "purpose": "Model tier for consults" },
    "review.consult.effort":                { "type": "enum", "values": ["minimal", "low", "medium", "high"], "default": "high", "src": "repo", "purpose": "Reasoning effort for consults" }
  }
}
